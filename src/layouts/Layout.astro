---
interface Props {
  title?: string;
}

const { title = 'Ben Barnes' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Ben Barnes personal website" />
    <meta name="theme-color" content="#FAF9F6" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="header-left">
          <a href="/" class="logo">Ben Barnes</a>
          <a href="https://www.instagram.com/benjaminbarnes/" target="_blank" class="instagram">@benjaminbarnes</a>
        </div>
        <nav>
          <a href="/">Writing</a>
          <a href="/gallery">Photos</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} &middot; <a href="mailto:benjaminrbarnes@gmail.com">benjaminrbarnes@gmail.com</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  body {
    font-family: 'EB Garamond', Georgia, serif;
    background: #FAF9F6;
    color: #2a2a2a;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    margin: 0;
    font-size: 1.25rem;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    width: 100%;
  }

  main.container {
    flex: 1;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  a {
    color: #2a2a2a;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: #000;
    text-decoration: none;
  }

  header {
    padding: 2rem 0;
    border-bottom: 1px solid #e0e0e0;
  }

  header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 500;
  }

  .instagram {
    font-size: 0.9rem;
    color: #5a6a8a;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .instagram:hover {
    color: #3a4a6a;
  }

  nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  nav a {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  nav a:hover {
    opacity: 1;
  }

  footer {
    padding: 2rem 0;
    border-top: 1px solid #e0e0e0;
    text-align: center;
    opacity: 0.5;
    font-size: 0.85rem;
  }

  /* Smooth image loading */
  img {
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @media (max-width: 768px) {
    body {
      font-size: 1.1rem;
    }

    header .container {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .header-left {
      flex-direction: column;
      gap: 0.5rem;
    }

    .logo {
      font-size: 1.25rem;
    }

    .instagram {
      font-size: 0.9rem;
    }

    nav {
      justify-content: center;
    }

    nav a {
      font-size: 0.9rem;
    }

    footer {
      font-size: 0.85rem;
    }
  }
</style>

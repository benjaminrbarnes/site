---
import Layout from '../layouts/Layout.astro';
import { getVisibleAlbums } from '../data/albums';

// Visible albums in file order (newest first — Austria 2025 leads).
const albums = getVisibleAlbums();
---

<Layout title="Ben Barnes" description="Photographs by Ben Barnes — travels, weddings, and ordinary days.">
  <div class="wrap">
    <div class="gallery gallery-top">
      {albums.map((album, i) => (
        <a class="card" href={`/album/${album.slug}`}>
          <div class="card-img">
            <img src={album.thumbnail} alt={album.title} loading={i < 3 ? 'eager' : 'lazy'} />
          </div>
          <div class="card-cap">
            <div class="ct">{album.title}</div>
            <div class="cd">{album.description}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

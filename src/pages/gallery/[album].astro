---
// Redirect shim: old album URLs lived at /gallery/<slug>; they now live at
// /album/<slug>. Emits a per-album redirect so existing links keep working.
import { getAllAlbums } from '../../data/albums';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return getAllAlbums().map(album => ({ params: { album: album.slug } }));
};

const { album } = Astro.params;
return Astro.redirect(`/album/${album}`, 301);
---

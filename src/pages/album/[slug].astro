---
import Layout from '../../layouts/Layout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getAllAlbums, getAlbum, getImageUrls } from '../../data/albums';
import ratios from '../../data/aspectRatios.json';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  // All albums get a route (hidden albums stay reachable via direct URL).
  return getAllAlbums().map(album => ({ params: { slug: album.slug } }));
};

const { slug } = Astro.params;
const album = getAlbum(slug as string);
if (!album) return Astro.redirect('/');

const images = getImageUrls(album, 800);
// Per-image aspect ratios (precomputed) let us reserve each photo's space
// before it loads, so the masonry never shifts. Fallback to 3:2 if missing.
const albumRatios: number[] = (ratios as Record<string, number[]>)[album.slug] ?? [];
---

<Layout title={`${album.title} — Ben Barnes`} description={album.description}>
  <div class="wrap">
    <div class="page">
      <nav class="crumb">
        <a href="/">Photos</a>
        <span class="sep">/</span>
        <span class="cur">{album.title}</span>
      </nav>
      <h1 class="page-title" style="margin-bottom: 6px;">{album.title}</h1>
      <div class="idx-sub" style="margin-bottom: 30px;">{album.description}</div>
      <div class="masonry">
        {images.map((src, i) => (
          <button class="m-item" aria-label="Open photo">
            <img src={src} alt="" loading="lazy" decoding="async" style={`aspect-ratio: ${albumRatios[i] ?? 1.5};`} />
          </button>
        ))}
      </div>
    </div>
  </div>
  <Lightbox />
</Layout>
